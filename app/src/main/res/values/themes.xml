<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base application theme. -->
    <style name="Theme.PhotoCleaner" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="android:windowBackground">@color/soft_background</item>
        <item name="android:statusBarColor">@color/soft_background</item>
        <item name="android:navigationBarColor">@color/soft_background</item>
    </style>

    <!-- Splash Screen theme. -->
    <style name="Theme.PhotoCleaner.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/soft_background</item>
        <item name="windowSplashScreenAnimatedIcon">@mipmap/ic_launcher</item>
        <item name="windowSplashScreenAnimationDuration">200</item>
        <item name="postSplashScreenTheme">@style/Theme.PhotoCleaner</item>
    </style>
</resources>
